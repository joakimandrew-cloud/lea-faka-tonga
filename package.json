{
  "name": "lea-faka-tonga-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:drills": "node scripts/validate-drill-map.mjs",
    "extract:all-exercises": "node scripts/extract-all-exercises.mjs",
    "build:vocab-index": "node scripts/build-vocab-index.mjs",
    "build:grammar-gates": "node scripts/build-grammar-gates.mjs",
    "audit:eva-build-indexes": "npm run extract:all-exercises && npm run build:vocab-index && npm run build:grammar-gates",
    "validate:exercises": "node scripts/validate-exercises.mjs",
    "audit:eva": "npm run audit:eva-build-indexes && npm run validate:exercises",
    "check:style": "node scripts/check-style.mjs",
    "check:locators": "node scripts/check-locators.mjs",
    "check:glosses": "node scripts/check-glosses.mjs",
    "check:grammaticality": "node scripts/check-grammaticality.mjs",
    "check:consistency": "node scripts/check-internal-consistency.mjs",
    "check:orthography": "node scripts/check-orthography.mjs",
    "check:fidelity": "node scripts/check-locators.mjs; node scripts/check-glosses.mjs; node scripts/check-grammaticality.mjs; node scripts/check-internal-consistency.mjs; node scripts/check-orthography.mjs",
    "build:source-map": "node scripts/build-source-map.mjs",
    "check:originality": "node scripts/check-originality.mjs",
    "audit:all": "npm run check:style && npm run validate:drills && npm run audit:eva"
  },
  "dependencies": {
    "@fontsource/charis-sil": "^5.2.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "rehype-raw": "^7.0.0",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  }
}
